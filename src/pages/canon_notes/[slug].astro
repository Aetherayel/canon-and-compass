---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import BottomLayout from "@layouts/BottomLayout.astro";
import ArticleTopLayout from "@layouts/ArticleTopLayout.astro";
import ArticleBottomLayout from "@layouts/ArticleBottomLayout.astro";
import PathwayLinks from "@components/PathwayLinks.astro";

export async function getStaticPaths() {
  const canonNotes = (await getCollection("canon_notes")).filter(
    (entry) => !entry.slug.includes("/"),
  );
  return canonNotes.map((note) => ({
    params: { slug: note.slug },
    props: note,
  }));
}

const canonNote = Astro.props;
const { title, summary } = canonNote.data;

// Pathway configuration for this note (if any)
const pathwayId = canonNote.data.pathwayId;
---

<PageLayout title={title} description={summary}>
  <TopLayout>
    <div class="animate">
      <ArticleTopLayout entry={canonNote} />
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">
      <ArticleBottomLayout entry={canonNote} />
    </div>
    {pathwayId && (
      <div class="mt-8">
        <PathwayLinks id={pathwayId} currentType="canonNote" />
      </div>
    )}
  </BottomLayout>
</PageLayout>
