---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import BottomLayout from "@layouts/BottomLayout.astro";
import ArticleTopLayout from "@layouts/ArticleTopLayout.astro";
import ArticleBottomLayout from "@layouts/ArticleBottomLayout.astro";
import ForestFruitPathLinks from "@components/ForestFruitPathLinks.astro";
import ManualButtons from "@components/ManualButtons.astro";
import {
  isForestOverview,
  isForestPathEntry,
  type ForestOverviewEntry,
  type ForestPathEntry,
} from "@lib/content";
import { cn } from "@lib/utils";

export async function getStaticPaths() {
  const forests = await getCollection("forests");

  const worldviewPaths = forests
    .filter((entry) => isForestPathEntry(entry) && !entry.data.draft)
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { type: "entry", entry },
    }));

  const forestPaths = forests
    .filter((entry) => isForestOverview(entry) && !entry.data.draft)
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { type: "forest", entry },
    }));

  return [...worldviewPaths, ...forestPaths];
}

type Props =
  | { type: "entry"; entry: ForestPathEntry }
  | { type: "forest"; entry: ForestOverviewEntry };

const props = Astro.props as Props;
const isForest = props.type === "forest";
const forest = isForest ? props.entry : null;
const worldview = isForest ? null : props.entry;

const pageTitle = forest?.data.title ?? worldview?.data.title ?? "";
const pageDescription = forest?.data.summary ?? worldview?.data.summary ?? "";
const seriesName = forest?.data.series ?? worldview?.data.series;

const forestEntries = (await getCollection("forests")).filter(isForestPathEntry);

const seriesEntries = seriesName
  ? forestEntries
      .filter(
        (entry) => entry.data.series === seriesName && !entry.data.draft,
      )
      .sort((a, b) => {
        const aPart = a.data.part ?? Number.MAX_SAFE_INTEGER;
        const bPart = b.data.part ?? Number.MAX_SAFE_INTEGER;
        if (aPart !== bPart) return aPart - bPart;
        return a.data.date.getTime() - b.data.date.getTime();
      })
  : [];

const activePart = worldview?.data.part;
const currentSeriesIndex = worldview
  ? seriesEntries.findIndex((entry) => entry.slug === worldview.slug)
  : -1;
const nextSeriesEntry =
  currentSeriesIndex >= 0 && currentSeriesIndex < seriesEntries.length - 1
    ? seriesEntries[currentSeriesIndex + 1]
    : undefined;

const splitParagraphs = (text: string) =>
  text
    .split(/\n\s*\n/)
    .map((paragraph) => paragraph.trim())
    .filter(Boolean);
---

<PageLayout
  title={pageTitle}
  description={pageDescription}
  pageType={isForest ? "website" : "article"}
  schemaType={isForest ? "CollectionPage" : "Article"}
  publishedTime={worldview?.data.date}
  section={isForest ? "The Forests" : worldview?.data.series}
  tags={worldview?.data.tags ?? []}
>
  {isForest ? (
    <>
      <TopLayout>
        <div class="animate space-y-3">
          <div class="flex flex-wrap items-center gap-2 text-xs uppercase text-pine dark:text-moss">
            <a href="/forests" class="transition-colors hover:text-ink dark:hover:text-bone">
              The Forests
            </a>
            <span class="text-pine/50 dark:text-moss/60">/</span>
            <span>{forest?.data.series} Forest</span>
          </div>
          <h1 class="mt-2 text-3xl font-semibold text-ink dark:text-bone">
            {forest?.data.title}
          </h1>
          <p class="text-lg text-ash dark:text-zinc-300">
            {forest?.data.subtitle}
          </p>
          <p class="text-sm text-pine/80 dark:text-moss">
            This is not a definition. It is a felt description.
          </p>
          <div class="rounded-2xl border border-pine/20 bg-pine/5 p-5 text-sm text-ash dark:border-pine/20 dark:bg-pine/10 dark:text-zinc-300">
            <div class="text-xs uppercase tracking-[0.2em] text-pine dark:text-moss">
              Read the Weather
            </div>
            <p class="mt-3 max-w-prose">
              Notice what feels familiar here, what feels safe, and what the climate quietly trains you to ignore.
            </p>
          </div>
        </div>
      </TopLayout>
      <BottomLayout>
        <div class="animate space-y-12">
          <section>
            <h2 class="text-xl font-semibold text-ink dark:text-bone">
              The Climate
            </h2>
            <div class="mt-3 space-y-3 text-base text-ash dark:text-zinc-300">
              {forest?.data.climate &&
                splitParagraphs(forest.data.climate).map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
            </div>
          </section>

          <section>
            <h2 class="text-xl font-semibold text-ink dark:text-bone">
              The Canopy
            </h2>
            <div class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">
              This is the unseen structure.
            </div>
            <ul class="mt-3 space-y-2 text-sm text-neutral-700 dark:text-neutral-300">
              {forest?.data.canopy?.map((item: string) => (
                <li class="flex items-start gap-2">
                  <span class="mt-2 h-1.5 w-1.5 rounded-full bg-pine/60 dark:bg-moss"></span>
                  <span>Under this canopy, {item}</span>
                </li>
              ))}
            </ul>
          </section>

          <section>
            <h2 class="text-xl font-semibold text-ink dark:text-bone">
              The Quiet Gospel
            </h2>
            <div class="mt-3 rounded-2xl border border-pine/20 bg-paper/80 p-5 text-sm text-ash shadow-sm dark:border-pine/25 dark:bg-zinc-900/70 dark:text-neutral-300">
              <div class="text-xs uppercase tracking-wide text-neutral-500 dark:text-neutral-400">
                The quiet gospel of this forest says:
              </div>
              <p class="mt-3 text-lg font-semibold text-ink dark:text-bone">
                "{forest?.data.quietGospel}"
              </p>
            </div>
          </section>

          <section>
            <h2 class="text-xl font-semibold text-ink dark:text-bone">
              The Fruit It Normalizes
            </h2>
            <ul class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2">
              {forest?.data.fruit?.map((item: string) => (
                <li class="rounded-xl border border-pine/20 bg-paper/80 p-3 text-sm text-ash shadow-sm dark:border-pine/25 dark:bg-zinc-900/70 dark:text-neutral-300">
                  {item}
                </li>
              ))}
            </ul>
          </section>

          <ForestFruitPathLinks forestSlug={forest?.slug} />

          <section>
            <h2 class="text-xl font-semibold text-ink dark:text-bone">
              The Cost of Staying
            </h2>
            <div class="mt-3 space-y-3 text-base text-ash dark:text-zinc-300">
              {forest?.data.costStaying &&
                splitParagraphs(forest.data.costStaying).map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
            </div>
          </section>

          <section>
            <h2 class="text-xl font-semibold text-ink dark:text-bone">
              The Cost of Leaving
            </h2>
            <div class="mt-3 space-y-3 text-base text-ash dark:text-zinc-300">
              {forest?.data.costLeaving &&
                splitParagraphs(forest.data.costLeaving).map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
            </div>
          </section>

          <section>
            <h2 class="text-xl font-semibold text-ink dark:text-bone">
              A Path Through the Forest
            </h2>
            <div class="mt-3 space-y-3 text-base text-ash dark:text-zinc-300">
              {forest?.data.pathIntro &&
                splitParagraphs(forest.data.pathIntro).map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
            </div>
            {seriesEntries.length > 0 ? (
              <ol class="mt-5 space-y-3">
                {seriesEntries.map((entry) => {
                  const partNumber = entry.data.part;
                  return (
                    <li>
                      <a
                        href={`/forests/${entry.slug}`}
                        class="block rounded-xl border border-pine/20 bg-paper/80 p-4 text-sm text-ash shadow-sm transition-colors duration-200 ease-in-out hover:border-pine/35 hover:bg-bone/70 dark:border-pine/25 dark:bg-zinc-900/70 dark:text-neutral-300 dark:hover:bg-white/10"
                      >
                        <div class="text-xs uppercase text-neutral-500 dark:text-neutral-400">
                          {partNumber ? `Part ${partNumber}` : "Entry"}
                        </div>
                        <div class="mt-1 font-semibold text-ink dark:text-bone">
                          {entry.data.title}
                        </div>
                        <div class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">
                          {entry.data.summary}
                        </div>
                      </a>
                    </li>
                  );
                })}
              </ol>
            ) : (
              <p class="mt-4 text-sm text-neutral-600 dark:text-neutral-400">
                This forest does not have trail markers yet.
              </p>
            )}
          </section>

          <section>
            <h2 class="text-xl font-semibold text-ink dark:text-bone">
              Gentle Orientation Forward
            </h2>
            <div class="mt-3 space-y-3 text-base text-ash dark:text-zinc-300">
              {forest?.data.orientation &&
                splitParagraphs(forest.data.orientation).map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
            </div>
            {forest?.data.orientationLink && (
              <a
                href={forest.data.orientationLink.href}
                class="mt-5 inline-flex items-center justify-center rounded-full border border-pine/40 px-4 py-2 text-sm font-semibold text-ink transition-colors duration-300 ease-in-out hover:bg-pine/10 dark:border-pine/35 dark:text-bone dark:hover:bg-pine/15"
              >
                {forest.data.orientationLink.label}
              </a>
            )}
          </section>
        </div>
      </BottomLayout>
    </>
  ) : (
    <>
      <TopLayout>
        <div class="animate space-y-3">
          <ArticleTopLayout entry={worldview!} />
          {worldview?.data.series &&
            worldview.data.series.toLowerCase() !== "standalone" && (
              <div class="flex flex-wrap items-center gap-2 text-xs uppercase text-neutral-600 dark:text-neutral-300">
                  <span class="rounded-full border border-pine/30 px-2 py-1 text-ink dark:border-pine/30 dark:text-bone">
                  {worldview.data.series}
                </span>
                <span>
                  {activePart ? `Part ${activePart}` : "Series entry"}
                  {seriesEntries.length > 1
                    ? ` of ${seriesEntries.length}`
                    : ""}
                </span>
              </div>
            )}
        </div>
      </TopLayout>
      <BottomLayout>
        <div class="animate">
          <ArticleBottomLayout entry={worldview!} />
        </div>

        {nextSeriesEntry && (
          <section class="animate mt-10">
            <ManualButtons
              nextHref={`/forests/${nextSeriesEntry.slug}`}
              nextLabel={nextSeriesEntry.data.title}
              nextType={
                nextSeriesEntry.data.part
                  ? `Part ${nextSeriesEntry.data.part} of ${seriesEntries.length}`
                  : "Next entry"
              }
            />
          </section>
        )}

        <section class="animate mt-10">
          <ForestFruitPathLinks series={worldview?.data.series} />
        </section>

        {seriesEntries.length > 1 && (
          <section class="animate mt-10">
            <h2 class="mb-3 text-base font-normal text-ink dark:text-bone">
              {worldview?.data.series} Series
            </h2>
            <ol class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {seriesEntries.map((entry) => {
                const isActive = entry.slug === worldview?.slug;
                const partNumber = entry.data.part;
                return (
                  <li>
                    <a
                      href={`/forests/${entry.slug}`}
                      class={cn(
                        "block h-full rounded-lg border p-4 transition-colors duration-200 ease-in-out",
                        "border-ash/20 dark:border-bone/15 hover:border-pine/35 hover:bg-bone/70 dark:hover:bg-white/10",
                        isActive &&
                          "pointer-events-none border-pine/40 bg-pine/10 dark:border-pine/35 dark:bg-pine/10",
                      )}
                      aria-current={isActive ? "page" : undefined}
                    >
                      <div class="text-xs uppercase text-neutral-600 dark:text-neutral-300">
                        {partNumber ? `Part ${partNumber}` : "Entry"}
                      </div>
                      <div class="mt-1 line-clamp-2 text-sm text-ink dark:text-bone">
                        {entry.data.title}
                      </div>
                      <div class="mt-1 line-clamp-2 text-sm text-ash dark:text-neutral-300">
                        {entry.data.summary}
                      </div>
                    </a>
                  </li>
                );
              })}
            </ol>
          </section>
        )}
      </BottomLayout>
    </>
  )}
</PageLayout>
