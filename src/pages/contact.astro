---
import PageLayout from "@layouts/PageLayout.astro"
import Container from "@components/Container.astro"

const pageTitle = "Contact"
const pageDescription =
  "Reach Canon & Compass with questions, corrections, or thoughtful feedback."
const contactEmail = "contact@canonandcompass.com"
const formAction = `https://formsubmit.co/${contactEmail}`
const pageOrigin = Astro.url.origin
const formUrl = new URL("/contact/", pageOrigin).toString()
const successUrl = new URL("/contact/thanks/", pageOrigin).toString()
---

<PageLayout title={pageTitle} description={pageDescription} schemaType="WebPage">
  <section class="bg-paper py-24 text-ink dark:bg-night dark:text-bone">
    <Container size="md">
      <div class="mx-auto max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-starlight">Reach out</p>
        <h1 class="mt-4 text-3xl font-serif font-bold tracking-tight md:text-4xl">
          Contact Canon & Compass
        </h1>
        <p class="mt-6 text-base text-ash dark:text-zinc-300 md:text-lg">
          Questions, corrections, or thoughtful feedback are welcome here.
        </p>
        <p class="mt-4 text-base text-ash dark:text-zinc-300">
          Canon & Compass is built to help readers tell the truth more carefully, not more loudly.
          If something here has been helpful, unclear, or in need of correction, you can use this
          page to send a note directly to the inbox behind the work.
        </p>
      </div>
    </Container>
  </section>

  <section class="bg-bone/45 py-20 text-ink dark:bg-zinc-950 dark:text-bone">
    <Container size="md">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="space-y-6">
          <div class="rounded-3xl border border-ash/15 bg-paper/80 p-6 shadow-sm dark:border-white/10 dark:bg-white/5">
            <h2 class="text-2xl font-serif font-bold tracking-tight">A measured line of contact</h2>
            <p class="mt-4 text-base text-ash dark:text-zinc-300">
              Use this form for thoughtful correspondence: questions about the work, factual
              corrections, permissions inquiries, or feedback that helps the project stay honest.
            </p>
            <p class="mt-4 text-base text-ash dark:text-zinc-300">
              Every message is read with care, but response times may vary and not every note will
              receive a personal reply.
            </p>
          </div>

          <div class="rounded-3xl border border-starlight/20 bg-starlight/10 p-6 dark:border-starlight/25 dark:bg-starlight/10">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-starlight">
              Direct email
            </p>
            <p class="mt-3 text-base text-ash dark:text-zinc-300">
              If you prefer, you can also write directly to
              <a
                href={`mailto:${contactEmail}`}
                class="underline underline-offset-4 decoration-starlight/50 transition-colors duration-300 ease-in-out hover:text-starlight hover:decoration-starlight"
              >
                {contactEmail}
              </a>.
            </p>
          </div>
        </div>

        <div class="rounded-[2rem] border border-ash/15 bg-paper p-6 shadow-sm dark:border-white/10 dark:bg-night/60 md:p-8">
          <form action={formAction} method="POST" class="space-y-5">
            <input type="hidden" name="_subject" value="New Canon & Compass contact form submission" />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_next" value={successUrl} />
            <input type="hidden" name="_url" value={formUrl} />
            <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" />

            <div class="grid gap-5 md:grid-cols-2">
              <label class="block">
                <span class="text-sm font-semibold text-ink dark:text-bone">Name</span>
                <input
                  type="text"
                  name="name"
                  autocomplete="name"
                  class="mt-2 w-full rounded-2xl border border-ash/20 bg-bone/40 px-4 py-3 text-base text-ink outline-none transition-colors duration-200 ease-in-out placeholder:text-ash/70 focus:border-starlight focus:bg-paper dark:border-white/10 dark:bg-white/5 dark:text-bone dark:focus:bg-white/[0.07]"
                  placeholder="How should I address you?"
                />
              </label>

              <label class="block">
                <span class="text-sm font-semibold text-ink dark:text-bone">Return email</span>
                <input
                  type="email"
                  name="email"
                  autocomplete="email"
                  class="mt-2 w-full rounded-2xl border border-ash/20 bg-bone/40 px-4 py-3 text-base text-ink outline-none transition-colors duration-200 ease-in-out placeholder:text-ash/70 focus:border-starlight focus:bg-paper dark:border-white/10 dark:bg-white/5 dark:text-bone dark:focus:bg-white/[0.07]"
                  placeholder="name@example.com"
                />
              </label>
            </div>

            <label class="block">
              <span class="text-sm font-semibold text-ink dark:text-bone">Subject</span>
              <input
                type="text"
                name="subject"
                required
                class="mt-2 w-full rounded-2xl border border-ash/20 bg-bone/40 px-4 py-3 text-base text-ink outline-none transition-colors duration-200 ease-in-out placeholder:text-ash/70 focus:border-starlight focus:bg-paper dark:border-white/10 dark:bg-white/5 dark:text-bone dark:focus:bg-white/[0.07]"
                placeholder="A brief line about what you’re writing for"
              />
            </label>

            <label class="block">
              <span class="text-sm font-semibold text-ink dark:text-bone">Message</span>
              <textarea
                name="message"
                required
                rows={8}
                class="mt-2 w-full rounded-[1.5rem] border border-ash/20 bg-bone/40 px-4 py-3 text-base text-ink outline-none transition-colors duration-200 ease-in-out placeholder:text-ash/70 focus:border-starlight focus:bg-paper dark:border-white/10 dark:bg-white/5 dark:text-bone dark:focus:bg-white/[0.07]"
                placeholder="Write as plainly as you need to."
              ></textarea>
            </label>

            <div class="flex flex-col gap-4 border-t border-ash/10 pt-2 dark:border-white/10">
              <p class="text-sm text-ash dark:text-zinc-300">
                This form forwards your note to the Canon & Compass inbox. Add a return email if
                you want the option of a reply.
              </p>
              <button
                type="submit"
                class="inline-flex w-full items-center justify-center rounded-full border border-starlight/40 bg-ink px-5 py-3 text-sm font-semibold text-bone transition-colors duration-200 ease-in-out hover:border-starlight hover:bg-starlight hover:text-ink dark:bg-bone dark:text-ink dark:hover:bg-starlight md:w-auto"
              >
                Send message
              </button>
            </div>
          </form>
        </div>
      </div>
    </Container>
  </section>
</PageLayout>
