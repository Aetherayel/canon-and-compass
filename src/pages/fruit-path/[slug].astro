---
import { getCollection, type CollectionEntry } from "astro:content";
import FruitPathPage from "@layouts/FruitPathPage.astro";

export async function getStaticPaths() {
  const entries = await getCollection("fruit-path");

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<"fruit-path">;
};

const slug = Astro.params.slug;
let entry = (Astro.props as Partial<Props>)?.entry;

if (!entry && slug) {
  const entries = await getCollection("fruit-path");
  entry = entries.find((candidate) => candidate.slug === slug);
}

if (!entry) {
  return Astro.redirect("/fruit-path");
}
---

<FruitPathPage
  entry={entry}
  backHref="/fruit-path"
  backLabel="Fruit Paths"
/>
