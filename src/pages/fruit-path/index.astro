---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import BottomLayout from "@layouts/BottomLayout.astro";
import SearchCollection from "@components/SearchCollection";
import { FRUIT_PATHS } from "@consts";
import { toCardEntry } from "@lib/cardEntries";

const entries = await getCollection("fruit-path");
const pathways = entries
  .filter((entry) => !(entry.data as any).draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const pathwayCards = pathways.map((entry) => toCardEntry(entry));
---

<PageLayout
  title={FRUIT_PATHS.TITLE}
  description={FRUIT_PATHS.DESCRIPTION}
  image="/fruit-paths-og.png"
  schemaType="CollectionPage"
  section="Fruit Paths"
>
  <TopLayout>
    <div class="animate">
      <div class="text-xs uppercase tracking-[0.2em] text-ember">Fruit Paths</div>
      <h1 class="mt-3 text-3xl font-semibold text-ink dark:text-bone">Fruit Paths</h1>
      <p class="mt-3 max-w-prose text-balance text-lg text-ash dark:text-zinc-400">
        What is growing in your life is trying to tell the truth.
      </p>
      <p class="mt-4 max-w-prose text-ash dark:text-zinc-400">
        Fruit Paths begin with what most people notice first - the anxiety that will not quiet, the
        exhaustion that lingers, the control that tightens, the hope that thins out.
      </p>
      <p class="mt-4 max-w-prose text-ash dark:text-zinc-400">
        These are not random flaws. They are fruit.
      </p>
      <p class="mt-4 max-w-prose text-ash dark:text-zinc-400">
        Fruit Paths exist to help you trace what is growing in your life back to its roots - and to
        re-root in truth that can actually sustain new growth under Christ.
      </p>
      <div class="mt-5 inline-flex flex-wrap gap-2 text-xs uppercase tracking-[0.18em]">
        <span class="rounded-full border border-ember/30 bg-ember/10 px-3 py-1 text-ink dark:border-ember/25 dark:bg-ember/10 dark:text-bone">
          Fruit tells the truth
        </span>
        <span class="rounded-full border border-moss/30 bg-moss/10 px-3 py-1 text-ink dark:border-moss/25 dark:bg-moss/10 dark:text-bone">
          Truth re-roots the heart
        </span>
      </div>
    </div>
    
  </TopLayout>

  <BottomLayout>
    <section class="animate mt-8 rounded-2xl border border-ember/15 bg-paper/70 p-6 dark:border-ember/15 dark:bg-zinc-900/40">
      <h2 class="text-2xl font-semibold text-ink dark:text-bone">What a Fruit Path Does</h2>
      <p class="mt-3 max-w-prose text-ash dark:text-zinc-400">
        Each Fruit Path follows a single, honest movement:
      </p>
      <p class="mt-3 font-semibold text-ink dark:text-bone">
        <span class="text-ember dark:text-ember">Fruit</span> -> misnaming -> root -> false center -> <span class="text-moss dark:text-moss">reordering truth</span> -> faithful step
      </p>
      <p class="mt-4 max-w-prose text-ash dark:text-zinc-400">
        Rather than jumping straight to solutions, a Fruit Path helps you:
      </p>
      <ul class="mt-4 max-w-prose list-disc space-y-2 pl-6 text-ash dark:text-zinc-400">
        <li>name what is showing up in your life</li>
        <li>notice what you may have been calling it instead</li>
        <li>trace the belief, wound, or training beneath it</li>
        <li>expose the false center or counterfeit gospel sustaining it</li>
        <li>receive the truth that puts reality back in place</li>
        <li>take one faithful next step instead of rehearsing the pattern again</li>
      </ul>
      <p class="mt-4 max-w-prose text-ash dark:text-zinc-400">
        This is not behavior management. It is repentance, witness, and re-rooting.
      </p>
    </section>

    <section class="animate mt-12">
      <h2 class="text-2xl font-semibold text-ink dark:text-bone">One Path, Two Trees</h2>
      <p class="mt-3 max-w-prose text-ash dark:text-zinc-400">
        Each Fruit Path walks between two trees - on the same ground.
      </p>

      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-ember/25 bg-paper/80 p-5 dark:border-ember/30 dark:bg-zinc-900/50">
          <h3 class="text-lg font-semibold text-ink dark:text-bone">The Counterfeit Tree</h3>
          <p class="mt-2 text-ash dark:text-zinc-400">
            This tree grows from a lie that may once have felt necessary to survive.
          </p>
          <p class="mt-2 text-ash dark:text-zinc-400">
            It often looks responsible. Sometimes it even borrows spiritual language.
          </p>
          <p class="mt-2 text-ash dark:text-zinc-400">
            But over time, it produces fruit that tells the truth about the root beneath it.
          </p>
        </div>

        <div class="rounded-xl border border-moss/25 bg-paper/80 p-5 dark:border-moss/30 dark:bg-zinc-900/50">
          <h3 class="text-lg font-semibold text-ink dark:text-bone">The Truth Tree</h3>
          <p class="mt-2 text-ash dark:text-zinc-400">
            This tree grows from biblical truth meant to be abided in, not merely applied.
          </p>
          <p class="mt-2 text-ash dark:text-zinc-400">
            Its fruit does not arrive all at once - but it is steadier, deeper, and more truthful.
          </p>
          <p class="mt-2 text-ash dark:text-zinc-400">
            A Fruit Path does not ask you to perform instant change. It traces how roots are surrendered and exchanged.
          </p>
        </div>
      </div>
    </section>

    <section id="why-symptoms" class="animate mt-12 scroll-mt-24">
      <h2 class="text-2xl font-semibold text-ink dark:text-bone">Why We Start with Fruit</h2>
      <p class="mt-3 max-w-prose text-ash dark:text-zinc-400">
        Most people do not begin by asking about beliefs or formation. They begin by feeling:
      </p>
      <ul class="mt-4 max-w-prose list-disc space-y-2 pl-6 text-ash dark:text-zinc-400">
        <li>tense</li>
        <li>tired</li>
        <li>reactive</li>
        <li>brittle</li>
        <li>overwhelmed</li>
        <li>or quietly numb</li>
      </ul>
      <p class="mt-4 max-w-prose text-ash dark:text-zinc-400">
        Fruit Paths take those experiences seriously. They begin with what you feel - and honor it enough to ask what it is revealing, what it has been misnamed, and what truth now requires.
      </p>
    </section>

    <section id="fruit-paths" class="animate mt-14 scroll-mt-24">
      <h2 class="text-2xl font-semibold text-ink dark:text-bone">The Fruit Paths</h2>
      <p class="mt-3 max-w-prose text-ash dark:text-zinc-400">
        Each path below starts close to the ground, with a familiar fruit that may already be shaping your reactions, relationships, or prayers.
      </p>
      <p class="mt-2 max-w-prose text-ash dark:text-zinc-400">
        You do not need to walk them all. One honest path is usually enough to begin.
      </p>

      <div class="animate mt-6">
        <SearchCollection
          client:load
          entry_name={"fruit paths"}
          tags={[]}
          data={pathwayCards}
          showTags={false}
          accent="ember"
        />
      </div>
    </section>

    <section class="animate mt-14">
      <h2 class="text-2xl font-semibold text-ink dark:text-bone">What Comes After the Path</h2>
      <p class="mt-3 max-w-prose text-ash dark:text-zinc-400">
        Naming the truth is not the same as being formed by it.
      </p>
      <p class="mt-3 max-w-prose text-ash dark:text-zinc-400">
        Some readers will want to keep tracing the wider climate that made this fruit feel normal. Others will need a sturdier conceptual frame for truth, reality, and lived obedience.
      </p>
      <p class="mt-3 max-w-prose text-ash dark:text-zinc-400">
        Fruit Paths stay close to lived experience. When you need wider diagnosis, go to The Forests. When you need slower conceptual reinforcement, go to Worldview Bearings.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/forests" class="inline-flex rounded-full border border-pine/45 px-4 py-2 text-sm font-semibold transition-colors hover:bg-pine/10 dark:border-pine/40 dark:hover:bg-pine/15">
          Explore The Forests
        </a>
        <a href="/the-clearing/worldview-bearings" class="inline-flex rounded-full border border-starlight/45 px-4 py-2 text-sm font-semibold transition-colors hover:bg-starlight/15 dark:border-starlight/40 dark:hover:bg-starlight/15">
          Enter Worldview Bearings
        </a>
      </div>
    </section>

    <section class="animate mt-14">
      <h2 class="text-2xl font-semibold text-ink dark:text-bone">If You Are Unsure Where to Begin</h2>
      <p class="mt-3 max-w-prose text-ash dark:text-zinc-400">
        If one fruit stands out clearly, start there. If everything feels tangled or loud, return to The Clearing first.
      </p>
      <p class="mt-3 max-w-prose text-ash dark:text-zinc-400">
        Fruit Paths are not meant to be rushed. They are meant to be walked honestly, with enough room for confession and return.
      </p>
      <div class="mt-4">
        <a href="/the-clearing" class="inline-flex rounded-full border border-starlight/45 px-4 py-2 text-sm font-semibold transition-colors hover:bg-starlight/15 dark:border-starlight/40 dark:hover:bg-starlight/15">
          Go to The Clearing
        </a>
      </div>
    </section>

    <section class="animate mt-14">
      <h2 class="text-2xl font-semibold text-ink dark:text-bone">A Gentle Word</h2>
      <p class="mt-3 max-w-prose text-ash dark:text-zinc-400">
        The fruit you are carrying tells a story.
      </p>
      <p class="mt-3 max-w-prose text-ash dark:text-zinc-400">
        Not just about your failure - but about the soil you have lived in, the pressures you adapted to, and the truths
        you were taught to survive by.
      </p>
      <p class="mt-3 max-w-prose text-ash dark:text-zinc-400">
        Fruit Paths exist to help you witness that story truthfully - and to return to Christ where a truer life can grow in its place.
      </p>
    </section>

  </BottomLayout>
</PageLayout>
