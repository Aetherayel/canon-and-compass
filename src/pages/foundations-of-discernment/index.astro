---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import BottomLayout from "@layouts/BottomLayout.astro";
import SearchCollection from "@components/SearchCollection";
import { FOUNDATIONSOFDISCERNMENT } from "@consts";
import { toCardEntry } from "@lib/cardEntries";

const foundations = (await getCollection("foundations-of-discernment"))
  .filter((note) => !note.data.draft)
  // Sort numerically by `day` so 2 comes after 1, not 11
  .sort((a, b) => {
    const da = Number(a.data.day ?? Number.POSITIVE_INFINITY);
    const db = Number(b.data.day ?? Number.POSITIVE_INFINITY);
    if (da !== db) return da - db;
    // Fallback: by date (desc) if same/missing day
    return b.data.date.getTime() - a.data.date.getTime();
  });

const tags = [
  ...new Set(foundations.flatMap((note) => note.data.tags)),
].sort((a, b) => a.localeCompare(b));
const foundationCards = foundations.map((note) => toCardEntry(note));

const estimated_initial_size =
  28 + foundations.length * 158 + (foundations.length - 1) * 12;
---

<PageLayout
  title={FOUNDATIONSOFDISCERNMENT.TITLE}
  description={FOUNDATIONSOFDISCERNMENT.DESCRIPTION}
  schemaType="CollectionPage"
  section="Foundations of Discernment"
>
  <TopLayout>
    <div class="animate">
      <h1 class="mt-2 text-3xl font-semibold text-ink dark:text-bone">
        {FOUNDATIONSOFDISCERNMENT.TITLE}
      </h1>
      <div class="mt-1 text-ash dark:text-zinc-300">
        {FOUNDATIONSOFDISCERNMENT.DESCRIPTION}
      </div>
    </div>
  </TopLayout>
  <BottomLayout>
    <div
      id="search-collection-wrapper"
      class="animate"
      style={{ minHeight: `${estimated_initial_size}px` }}
    >
      <SearchCollection
        client:load
        entry_name={"notes"}
        tags={tags}
        data={foundationCards}
      />
    </div>
  </BottomLayout>
</PageLayout>
