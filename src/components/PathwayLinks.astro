---
export interface Props {
  id: string;                // pathway id e.g., emotional-reactivity_spirit-led-identity
  currentType?: 'path' | 'counterfeitTree' | 'canonNote' | 'compassPoint' | 'pillar';
  currentHref?: string;      // optional explicit href to mark as current
  showPath?: boolean;
  showTree?: boolean;
  showCounterfeit?: boolean;
  showShift?: boolean;
  showCanonNote?: boolean;
  showCompassPoint?: boolean;
  showPillar?: boolean;
  heading?: string;
  blurb?: string;
  accent?: "starlight" | "pine" | "ember" | "moss" | "fig";
}

import { getCollection } from 'astro:content';

const props = Astro.props as Props;
const {
  id,
  currentType,
  currentHref,
  showPath = true,
  showTree = false,
  showCounterfeit = true,
  showShift = false,
  showCanonNote = true,
  showCompassPoint = true,
  showPillar = true,
  heading = 'Related Pathway Links',
  blurb = 'Follow the connected witness around this Fruit Path.',
  accent = 'starlight',
} = props;

const pathways = await getCollection('fruit-path');
const entry = pathways.find((p) => (p.data?.pathwayId ?? p.slug) === id);
const data: any = entry?.data ?? {};

function hrefOr(base: string, item: any, anchor?: string) {
  if (!item) return undefined;
  if (item.href) return item.href;
  if (base === "/fruit-path" && id) return `${base}/${id}${anchor ?? ""}`;
  if (item.slug) return `${base}/${item.slug}`;
  return undefined;
}

type TypeKey = 'path' | 'shift' | 'tree' | 'counterfeitTree' | 'canonNote' | 'compassPoint' | 'pillar';
const pathItem = data
  ? { title: data?.label ?? data?.title ?? 'Fruit Path' }
  : undefined;

const order: Array<{key: TypeKey; label: string; base: string; show: boolean; item: any; anchor?: string}> = [
  { key: 'path', label: 'Fruit Path', base: '/fruit-path', show: showPath, item: pathItem },
  { key: 'shift', label: 'Symptom', base: '/fruit-path', anchor: '#symptom', show: showShift, item: data?.shift },
  { key: 'tree', label: 'Truth Tree', base: '/fruit-path', anchor: '#truth-tree', show: showTree, item: data?.tree },
  { key: 'counterfeitTree', label: 'Counterfeit Tree', base: '/counterfeit-tree', show: showCounterfeit, item: data?.counterfeitTree },
  { key: 'canonNote', label: 'Canon Note', base: '/canon_notes', show: showCanonNote, item: data?.canonNote },
  { key: 'compassPoint', label: 'Compass Point', base: '/compass_points', show: showCompassPoint, item: data?.compassPoint },
  { key: 'pillar', label: 'Pillar', base: '/pillars', show: showPillar, item: data?.pillar },
];

const currentPath = (() => {
  try {
    const p = Astro.url?.pathname ?? '';
    return p.endsWith('/') ? p : p + '/';
  } catch {
    return '';
  }
})();

const entriesList = order
  .filter(e => e.show && e.item)
  .map(e => {
    const title = e.item?.title ?? (e.item?.slug ? e.item.slug.replace(/-/g, ' ') : e.label);
    const href = hrefOr(e.base, e.item, e.anchor);
    const cleanedHref = href ? href.split('#')[0] : undefined;
    const normalizedHref = cleanedHref ? (cleanedHref.endsWith('/') ? cleanedHref : cleanedHref + '/') : undefined;
    const isCurrent = (currentType && currentType === e.key) || (currentHref && currentHref === href) || (normalizedHref && normalizedHref === currentPath);
    return { key: e.key, typeLabel: e.label, title, href, isCurrent };
  });

const accentStyles =
  accent === "pine"
    ? {
        section: "border-pine/20 dark:border-pine/20",
        summaryHover: "hover:bg-pine/10 dark:hover:bg-pine/10",
        arrow: "text-pine dark:text-moss",
        badge: "border-pine/20 bg-pine/10 dark:border-pine/20 dark:bg-pine/10",
        current: "border-pine/45 bg-pine/10 dark:border-pine/35 dark:bg-pine/10",
        currentText: "text-pine dark:text-moss",
        link: "hover:border-pine/35 hover:bg-bone/70 dark:hover:border-pine/30 dark:hover:bg-white/10",
        linkArrow: "group-hover:text-pine dark:group-hover:text-pine",
      }
    : accent === "ember"
      ? {
          section: "border-ember/20 dark:border-ember/20",
          summaryHover: "hover:bg-ember/10 dark:hover:bg-ember/10",
          arrow: "text-ember dark:text-ember",
          badge: "border-ember/20 bg-ember/10 dark:border-ember/20 dark:bg-ember/10",
          current: "border-ember/45 bg-ember/10 dark:border-ember/35 dark:bg-ember/10",
          currentText: "text-ember dark:text-ember",
          link: "hover:border-ember/35 hover:bg-bone/70 dark:hover:border-ember/30 dark:hover:bg-white/10",
          linkArrow: "group-hover:text-ember dark:group-hover:text-ember",
        }
      : accent === "moss"
        ? {
            section: "border-moss/20 dark:border-moss/20",
            summaryHover: "hover:bg-moss/10 dark:hover:bg-moss/10",
            arrow: "text-moss dark:text-moss",
            badge: "border-moss/20 bg-moss/10 dark:border-moss/20 dark:bg-moss/10",
            current: "border-moss/45 bg-moss/10 dark:border-moss/35 dark:bg-moss/10",
            currentText: "text-moss dark:text-moss",
            link: "hover:border-moss/35 hover:bg-bone/70 dark:hover:border-moss/30 dark:hover:bg-white/10",
            linkArrow: "group-hover:text-moss dark:group-hover:text-moss",
          }
        : accent === "fig"
          ? {
              section: "border-fig/20 dark:border-fig/20",
              summaryHover: "hover:bg-fig/10 dark:hover:bg-fig/10",
              arrow: "text-fig dark:text-fig",
              badge: "border-fig/20 bg-fig/10 dark:border-fig/20 dark:bg-fig/10",
              current: "border-fig/45 bg-fig/10 dark:border-fig/35 dark:bg-fig/10",
              currentText: "text-fig dark:text-fig",
              link: "hover:border-fig/35 hover:bg-bone/70 dark:hover:border-fig/30 dark:hover:bg-white/10",
              linkArrow: "group-hover:text-fig dark:group-hover:text-fig",
            }
          : {
              section: "border-starlight/20 dark:border-starlight/20",
              summaryHover: "hover:bg-starlight/10 dark:hover:bg-starlight/10",
              arrow: "text-starlight dark:text-starlight",
              badge: "border-starlight/20 bg-starlight/10 dark:border-starlight/20 dark:bg-starlight/10",
              current: "border-starlight/45 bg-starlight/10 dark:border-starlight/35 dark:bg-starlight/10",
              currentText: "text-starlight dark:text-starlight",
              link: "hover:border-starlight/35 hover:bg-bone/70 dark:hover:border-starlight/30 dark:hover:bg-white/10",
              linkArrow: "group-hover:text-starlight dark:group-hover:text-starlight",
            };
---

<section class={`mt-8 rounded-xl border bg-paper/70 backdrop-blur dark:bg-zinc-900/50 ${accentStyles.section}`}>
  <style>
    .pw-summary { cursor: pointer; list-style: none; }
    .pw-summary::-webkit-details-marker { display: none; }
    .pw-arrow { transition: transform .25s ease; }
    details[open] .pw-arrow { transform: rotate(90deg); }
    .pw-content { transition: opacity .25s ease, transform .25s ease; transform-origin: top center; }
    details:not([open]) .pw-content { opacity: 0; transform: translateY(-6px) scale(.995); height: 0; overflow: hidden; }
    details[open] .pw-content { opacity: 1; transform: translateY(0) scale(1); height: auto; }
  </style>
  <details>
    <summary class={`pw-summary flex items-center justify-between gap-3 rounded-md p-4 ${accentStyles.summaryHover}`}>
      <div class="flex items-center gap-3 min-w-0">
        <svg aria-hidden="true" class={`pw-arrow h-4 w-4 ${accentStyles.arrow}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <h3 class="truncate text-base font-semibold text-ink dark:text-bone">{heading}</h3>
      </div>
      <div class={`rounded-full border px-2 py-0.5 text-xs text-ash dark:text-zinc-400 ${accentStyles.badge}`}>{entriesList.length}</div>
    </summary>

    <div class="pw-content px-4 pb-4">
      {blurb && <p class="mb-3 text-sm text-ash dark:text-zinc-400">{blurb}</p>}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {entriesList.map((e) => (
          e.isCurrent ? (
            <div class={`cursor-default select-none rounded-lg border p-3.5 flex items-center justify-between gap-3 ${accentStyles.current}`}>
              <div class="min-w-0">
                <div class={`text-xs font-semibold uppercase tracking-wide ${accentStyles.currentText}`}>{e.typeLabel}</div>
                <div class="truncate text-sm font-medium text-ink dark:text-bone">{e.title}</div>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class={`stroke-current ${accentStyles.currentText}`}>
                <circle cx="12" cy="12" r="2" />
              </svg>
            </div>
          ) : (
            <a href={e.href} class={`group flex items-center justify-between gap-3 rounded-lg border border-ash/20 p-3.5 transition-colors dark:border-bone/15 ${accentStyles.link}`}>
              <div class="min-w-0">
                <div class="text-xs font-semibold uppercase tracking-wide text-ash dark:text-zinc-400">{e.typeLabel}</div>
                <div class="truncate text-sm font-medium text-ink dark:text-bone">{e.title}</div>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class={`stroke-current text-ash transition-colors duration-300 ease-in-out ${accentStyles.linkArrow}`}>
                <line x1="5" y1="12" x2="19" y2="12" class="scale-x-0 group-hover:scale-x-100 translate-x-4 group-hover:translate-x-1 transition-all duration-300 ease-in-out" />
                <polyline points="12 5 19 12 12 19" class="translate-x-0 group-hover:translate-x-1 transition-all duration-300 ease-in-out" />
              </svg>
            </a>
          )
        ))}
      </div>

      {!entry && (
        <p class="mt-2 text-xs text-amber-600 dark:text-amber-400">Unknown pathway id: {id}</p>
      )}

      <div class="mt-2 text-[10px] uppercase tracking-wide text-ash/70 dark:text-zinc-500">Pathway Context</div>
    </div>
  </details>
</section>
