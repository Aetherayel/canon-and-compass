---
interface Props {
  title?: string
}

const { title = "Care note" } = Astro.props
---

<aside class="my-6 rounded-xl border border-amber-300/60 bg-amber-50/80 p-4 text-sm text-amber-950 dark:border-amber-500/40 dark:bg-amber-950/20 dark:text-amber-100">
  <div class="font-semibold uppercase tracking-wide text-[11px]">{title}</div>
  <div class="mt-2 leading-relaxed">
    <slot />
  </div>
</aside>
