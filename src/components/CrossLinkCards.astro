---
export interface CrossLinkItem {
  href: string;
  label: string;
  title: string;
  description: string;
  meta?: string;
}

export interface Props {
  eyebrow?: string;
  heading: string;
  blurb: string;
  items: CrossLinkItem[];
}

const { eyebrow, heading, blurb, items } = Astro.props as Props;
---

{
  items.length > 0 && (
    <section class="rounded-2xl border border-black/10 bg-white/70 p-6 shadow-sm dark:border-white/15 dark:bg-zinc-900/70">
      {eyebrow && (
        <div class="text-xs uppercase tracking-[0.2em] text-zinc-500 dark:text-zinc-400">
          {eyebrow}
        </div>
      )}
      <h2 class="mt-3 text-base font-normal text-black dark:text-white">
        {heading}
      </h2>
      <p class="mt-3 max-w-prose text-sm text-zinc-600 dark:text-zinc-400">
        {blurb}
      </p>

      <div class="mt-5 grid gap-3 sm:grid-cols-2">
        {items.map((item) => (
          <a
            href={item.href}
            class="group rounded-xl border border-black/10 bg-white/75 p-4 transition-colors duration-200 ease-in-out hover:bg-black/5 dark:border-white/15 dark:bg-zinc-950/40 dark:hover:bg-white/10"
          >
            <div class="text-xs uppercase tracking-wide text-zinc-500 dark:text-zinc-400">
              {item.label}
            </div>
            <div class="mt-2 flex items-start justify-between gap-3">
              <div class="min-w-0">
                <h3 class="text-sm font-normal text-black dark:text-white">
                  {item.title}
                </h3>
                {item.meta && (
                  <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                    {item.meta}
                  </p>
                )}
              </div>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="mt-0.5 shrink-0 stroke-current text-zinc-500 transition-colors duration-200 ease-in-out group-hover:text-black dark:group-hover:text-white"
              >
                <line
                  x1="5"
                  y1="12"
                  x2="19"
                  y2="12"
                  class="scale-x-0 translate-x-4 transition-all duration-300 ease-in-out group-hover:translate-x-1 group-hover:scale-x-100"
                />
                <polyline
                  points="12 5 19 12 12 19"
                  class="translate-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1"
                />
              </svg>
            </div>
            <p class="mt-3 text-sm text-zinc-700 dark:text-zinc-300">
              {item.description}
            </p>
          </a>
        ))}
      </div>
    </section>
  )
}
