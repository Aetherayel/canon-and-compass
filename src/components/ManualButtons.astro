---
export interface Props {
  prevHref?: string
  prevLabel?: string
  prevType?: string
  nextHref?: string
  nextLabel?: string
  nextType?: string
}

const {
  prevHref,
  prevLabel = "Previous",
  prevType = "",
  nextHref,
  nextLabel = "Next",
  nextType = ""
} = Astro.props
---
<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
  {prevHref && (
    <a href={prevHref} class="group blend flex items-center gap-3 rounded-lg border border-ash/20 bg-paper/70 p-4 transition-colors duration-300 ease-in-out hover:border-starlight/40 hover:bg-bone/70 dark:border-bone/15 dark:bg-zinc-900/70 dark:hover:bg-white/10">
      <div class="order-2 h-full w-full blend">
        <div class="flex flex-wrap gap-2 items-center">
          <div class="text-xs font-semibold uppercase tracking-wide text-starlight">
            PREV
          </div>
          {prevType && (
            <div class="ml-2 text-xs uppercase text-ash dark:text-zinc-400">
              {prevType}
            </div>
          )}
        </div>
        <div class="mt-3 font-semibold text-ink dark:text-bone">
          {prevLabel}
        </div>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="order-1 rotate-180 stroke-current text-ash transition-colors duration-300 ease-in-out group-hover:text-starlight">
        <line x1="5" y1="12" x2="19" y2="12" class="scale-x-0 group-hover:scale-x-100 translate-x-4 group-hover:translate-x-1 transition-all duration-300 ease-in-out" />
        <polyline points="12 5 19 12 12 19" class="translate-x-0 group-hover:translate-x-1 transition-all duration-300 ease-in-out" />
      </svg>
    </a>
  )}
  {nextHref && (
    <a href={nextHref} class="group flex items-center gap-3 rounded-lg border border-ash/20 bg-paper/70 p-4 transition-colors duration-300 ease-in-out hover:border-starlight/40 hover:bg-bone/70 dark:border-bone/15 dark:bg-zinc-900/70 dark:hover:bg-white/10">
      <div class="blend h-full w-full text-right">
        <div class="flex flex-wrap gap-2 justify-end items-center">
          <div class="text-xs font-semibold uppercase tracking-wide text-starlight">
            NEXT
          </div>
          {nextType && (
            <div class="ml-2 text-xs uppercase text-ash dark:text-zinc-400">
              {nextType}
            </div>
          )}
        </div>
        <div class="mt-3 font-semibold text-ink dark:text-bone">
          {nextLabel}
        </div>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="stroke-current text-ash transition-colors duration-300 ease-in-out group-hover:text-starlight">
        <line x1="5" y1="12" x2="19" y2="12" class="scale-x-0 group-hover:scale-x-100 translate-x-4 group-hover:translate-x-1 transition-all duration-300 ease-in-out" />
        <polyline points="12 5 19 12 12 19" class="translate-x-0 group-hover:translate-x-1 transition-all duration-300 ease-in-out" />
      </svg>
    </a>
  )}
</div>
