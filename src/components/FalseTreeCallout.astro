---
/**
 * Props:
 *  - title: string
 *  - data: {
 *      root: string,
 *      rootReflection?: string,
 *      trunk: string,
 *      trunkReflection?: string,
 *      branches: string[],
 *      branchesReflection?: string,
 *      leaves: string[],
 *      leavesReflection?: string,
 *      fruit: string[],
 *      fruitReflection?: string,
 *    }
 */
const { title = "Bad Tree Walkthrough", data = {} } = Astro.props;

const {
  root = "Core lie goes here.",
  rootReflection = "Where do you notice this lie showing up in your thoughts or actions?",
  trunk = "The false belief that supports it.",
  trunkReflection = "How does this belief affect your relationships or choices?",
  branches = [],
  branchesReflection = "Notice when these patterns show up. What triggers them?",
  leaves = [],
  leavesReflection = "What small step could interrupt this habit today?",
  fruit = [],
  fruitReflection = "Which of these outcomes do you want to change?"
} = data;
---
<style>
  .btw-summary::marker { display: none; }
  .btw-summary { cursor: pointer; }
  .btw-arrow { transition: transform .25s ease; }
  details[open] .btw-arrow { transform: rotate(90deg); }
  .btw-content { transition: opacity .28s ease, transform .28s ease; transform-origin: top center; }
  details:not([open]) .btw-content { opacity: 0; transform: translateY(-6px) scale(.995); height: 0; overflow: hidden; }
  details[open] .btw-content { opacity: 1; transform: translateY(0) scale(1); height: auto; }
</style>

<div class="rounded-2xl border border-ember/30 bg-paper p-6 space-y-4 shadow-sm dark:border-ember/35 dark:bg-zinc-900">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h3 class="text-lg font-serif font-semibold text-ember dark:text-ember">{title}</h3>
      <p class="mt-1 max-w-prose text-sm text-ash dark:text-zinc-400">
        Walk through the core parts of this tree, following the fruit - what you are seeing - to the root lie. Expand each section for a short explanation and reflection prompts.
      </p>
    </div>
  </div>

  <div class="mt-4 space-y-3">
    <!-- Fruit -->
    <details class="rounded-lg" role="group">
      <summary class="btw-summary flex items-center gap-3 rounded-md p-3 hover:bg-ember/10 dark:hover:bg-ember/10">
        <svg class="btw-arrow h-4 w-4 text-ember" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <div class="text-sm font-medium text-ink dark:text-bone"> Fruit — Visible outcomes</div>
      </summary>
      <div class="btw-content rounded-b-md bg-ember/10 p-4 dark:bg-zinc-950">
        <ul class="list-disc list-inside space-y-1 text-sm text-ash dark:text-zinc-300">
          {fruit.length ? fruit.map((f: string) => (<li>{f}</li>)) : (<li class="text-ash">No fruit specified.</li>)}
        </ul>
        <div class="mt-3 text-xs text-ember dark:text-ember">
          <strong>Reflection:</strong> {fruitReflection}
        </div>
      </div>
    </details>

    <!-- Leaves -->
    <details class="rounded-lg" role="group">
      <summary class="btw-summary flex items-center gap-3 rounded-md p-3 hover:bg-ember/10 dark:hover:bg-ember/10">
        <svg class="btw-arrow h-4 w-4 text-ember" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <div class="text-sm font-medium text-ink dark:text-bone"> Leaves — Everyday actions</div>
      </summary>
      <div class="btw-content rounded-b-md bg-ember/10 p-4 dark:bg-zinc-950">
        <ul class="list-disc list-inside space-y-1 text-sm text-ash dark:text-zinc-300">
          {leaves.length ? leaves.map((l: string) => (<li>{l}</li>)) : (<li class="text-ash">No leaves specified.</li>)}
        </ul>
        <div class="mt-3 text-xs text-ember dark:text-ember">
          <strong>Prompt:</strong> {leavesReflection}
        </div>
      </div>
    </details>

    <!-- Branches -->
    <details class="rounded-lg" role="group">
      <summary class="btw-summary flex items-center gap-3 rounded-md p-3 hover:bg-ember/10 dark:hover:bg-ember/10">
        <svg class="btw-arrow h-4 w-4 text-ember" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <div class="text-sm font-medium text-ink dark:text-bone"> Branches — Reinforcing patterns</div>
      </summary>
      <div class="btw-content rounded-b-md bg-ember/10 p-4 dark:bg-zinc-950">
        <ul class="list-disc list-inside space-y-1 text-sm text-ash dark:text-zinc-300">
          {branches.length ? branches.map((b: string) => (<li>{b}</li>)) : (<li class="text-ash">No branches specified.</li>)}
        </ul>
        <div class="mt-3 text-xs text-ember dark:text-ember">
          <strong>Try:</strong> {branchesReflection}
        </div>
      </div>
    </details>

    <!-- Trunk (False Belief) -->
    <details class="rounded-lg" role="group">
      <summary class="btw-summary flex items-center gap-3 rounded-md p-3 hover:bg-ember/10 dark:hover:bg-ember/10">
        <svg class="btw-arrow h-4 w-4 text-ember" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <div class="text-sm font-medium text-ink dark:text-bone"> Trunk — False belief</div>
      </summary>
      <div class="btw-content rounded-b-md bg-ember/10 p-4 dark:bg-zinc-950">
        <p class="text-sm text-ash dark:text-zinc-300">{trunk}</p>
        <div class="mt-3 text-xs text-ember dark:text-ember">
          <strong>Reflect:</strong> {trunkReflection}
        </div>
      </div>
    </details>

    <!-- Root (Core Lie) -->
    <details class="rounded-lg" role="group">
      <summary class="btw-summary flex items-center gap-3 rounded-md p-3 hover:bg-ember/10 dark:hover:bg-ember/10">
        <svg class="btw-arrow h-4 w-4 text-ember" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <div class="text-sm font-medium text-ink dark:text-bone"> Root — Core lie</div>
      </summary>
      <div class="btw-content rounded-b-md bg-ember/10 p-4 dark:bg-zinc-950">
        <p class="text-sm text-ash dark:text-zinc-300">{root}</p>
        <div class="mt-3 text-xs text-ember dark:text-ember">
          <strong>Reflect:</strong> {rootReflection}
        </div>
      </div>
    </details>
