---
import { SITE } from "@consts"

type JsonLdNode = Record<string, unknown>

interface Props {
  title: string
  description: string
  image?: string
  pageType?: "website" | "article"
  schemaType?: "WebPage" | "CollectionPage" | "AboutPage" | "SearchResultsPage" | "Article" | "WebSite"
  publishedTime?: Date | string
  modifiedTime?: Date | string
  section?: string
  tags?: string[]
  author?: string
  structuredData?: JsonLdNode | JsonLdNode[]
}

const {
  title,
  description,
  image = "/canonandcompass-og.png",
  pageType = "website",
  schemaType = "WebPage",
  publishedTime,
  modifiedTime,
  section,
  tags = [],
  author = SITE.AUTHOR,
  structuredData,
} = Astro.props as Props

const siteURL = Astro.site ?? new URL(Astro.url.origin)
const canonicalURL = new URL(Astro.url.pathname, siteURL)
const pageURL = canonicalURL.href
const socialImageURL = new URL(image, siteURL)
const rssURL = new URL("/rss.xml", siteURL)

const toISODate = (value?: Date | string) => {
  if (!value) return undefined
  const date = value instanceof Date ? value : new Date(value)
  return Number.isNaN(date.getTime()) ? undefined : date.toISOString()
}

const cleanObject = (value: Record<string, unknown>) =>
  Object.fromEntries(
    Object.entries(value).filter(([, entry]) => {
      if (entry === undefined || entry === null) return false
      if (Array.isArray(entry)) return entry.length > 0
      return true
    }),
  )

const serializeJsonLd = (value: JsonLdNode) =>
  JSON.stringify(value).replace(/</g, "\\u003c")

const publishedISO = toISODate(publishedTime)
const modifiedISO = toISODate(modifiedTime) ?? publishedISO
const basePublisher = {
  "@type": "Organization",
  name: SITE.TITLE,
  url: siteURL.href,
}

const baseSchema =
  pageType === "article"
    ? cleanObject({
        "@context": "https://schema.org",
        "@type": schemaType,
        headline: title,
        description,
        url: pageURL,
        image: socialImageURL.href,
        datePublished: publishedISO,
        dateModified: modifiedISO,
        articleSection: section,
        keywords: tags,
        author: {
          "@type": "Person",
          name: author,
        },
        publisher: basePublisher,
        mainEntityOfPage: pageURL,
        inLanguage: "en",
      })
    : cleanObject({
        "@context": "https://schema.org",
        "@type": schemaType,
        name: schemaType === "WebSite" ? SITE.TITLE : title,
        description: schemaType === "WebSite" ? SITE.DESCRIPTION : description,
        url: pageURL,
        image: socialImageURL.href,
        isPartOf:
          schemaType === "WebSite"
            ? undefined
            : {
                "@type": "WebSite",
                name: SITE.TITLE,
                url: siteURL.href,
              },
        about: section,
        keywords: tags,
        inLanguage: "en",
      })

const structuredDataNodes = [
  baseSchema,
  ...(Array.isArray(structuredData)
    ? structuredData
    : structuredData
      ? [structuredData]
      : []),
]
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<meta name="author" content={SITE.AUTHOR} />
<meta name="robots" content="index,follow" />

<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin>
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={pageType} />
<meta property="og:site_name" content={SITE.TITLE} />
<meta property="og:url" content={pageURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImageURL.href} />
{pageType === "article" && publishedISO && (
  <meta property="article:published_time" content={publishedISO} />
)}
{pageType === "article" && modifiedISO && (
  <meta property="article:modified_time" content={modifiedISO} />
)}
{pageType === "article" && section && (
  <meta property="article:section" content={section} />
)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={pageURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={socialImageURL.href} />

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- RSS Feed -->
<link rel="alternate" type="application/rss+xml" title={`${SITE.TITLE} RSS`} href={rssURL.href} />

<!-- Structured Data -->
{
  structuredDataNodes.map((node) => (
    <script is:inline type="application/ld+json" set:html={serializeJsonLd(node)} />
  ))
}

<!-- Global Scripts -->
<script is:inline src="/js/theme.js"></script>
<script is:inline src="/js/scroll.js"></script>
<script is:inline src="/js/animate.js"></script>
<script defer is:inline src="/js/copy.js"></script>

<!-- <ViewTransitions  /> -->

<script>
  import type { TransitionBeforeSwapEvent } from "astro:transitions/client"
  document.addEventListener("astro:before-swap", (e) =>
    [
      ...(e as TransitionBeforeSwapEvent).newDocument.head.querySelectorAll(
        "link[as=\"font\"]"
      ),
    ].forEach((link) => link.remove())
  )
</script>
