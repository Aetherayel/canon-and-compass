---
import { SITE, LINKS } from "@consts"
import { cn } from "@lib/utils"
const { pathname } = Astro.url

const isActivePath = (href: string) => {
  if (href === "/") return pathname === "/"
  return pathname === href || pathname.startsWith(`${href}/`)
}

const isFruitPathActive = isActivePath("/fruit-path")
---

<div id="drawer" class="fixed inset-0 z-40 flex h-0 flex-col items-center justify-center overflow-hidden bg-paper text-ink/85 transition-[height] duration-300 ease-in-out dark:bg-night dark:text-bone md:hidden">
  <nav class="flex w-full flex-col items-center gap-2 px-6">
    {
      LINKS.map((LINK) => {
        const isActive =
          LINK.TEXT === "Fruit Paths"
            ? isFruitPathActive
            : isActivePath(LINK.HREF)
        return (
          <a href={LINK.HREF} class={cn(
            "flex items-center justify-center rounded-full px-3 py-1",
            "text-current hover:text-ink dark:hover:text-bone",
            "hover:bg-bone/70 dark:hover:bg-white/10",
            "transition-colors duration-300 ease-in-out",
            isActive ? "pointer-events-none bg-ink text-bone dark:bg-bone dark:text-ink" : "",
          )} aria-current={isActive ? "page" : undefined}>
            {LINK.TEXT}
          </a>
        )
      })
    }
  </nav>

  <div class="flex gap-1 mt-5">
      <a href="/search" aria-label={`Search the site on ${SITE.TITLE}`} class={cn("size-9 rounded-full border border-ash/20 p-2 items-center justify-center bg-transparent stroke-current transition-colors duration-300 ease-in-out hover:border-starlight/50 hover:bg-bone/60 hover:text-ink dark:border-bone/15 dark:hover:bg-white/10 dark:hover:text-bone", isActivePath("/search") ? "pointer-events-none border-starlight bg-starlight text-ink" : "")}>
      <svg class="size-full">
        <use href="/ui.svg#search"></use>
      </svg>
    </a>

    <a href="/rss.xml" target="_blank" aria-label={`Rss feed for ${SITE.TITLE}`} class="size-9 rounded-full border border-ash/20 p-2 items-center justify-center bg-transparent stroke-current transition-colors duration-300 ease-in-out hover:border-starlight/50 hover:bg-bone/60 hover:text-ink dark:border-bone/15 dark:hover:bg-white/10 dark:hover:text-bone">
      <svg class="size-full">
        <use href="/ui.svg#rss"></use>
      </svg>
    </a>

    <button id="drawer-theme-button" aria-label={`Toggle light and dark theme`} class="size-9 rounded-full border border-ash/20 p-2 items-center justify-center bg-transparent stroke-current transition-colors duration-300 ease-in-out hover:border-starlight/50 hover:bg-bone/60 hover:text-ink dark:border-bone/15 dark:hover:bg-white/10 dark:hover:text-bone">
      <svg class="block dark:hidden size-full">
        <use href="/ui.svg#sun"></use>
      </svg>
      <svg class="hidden dark:block size-full">
        <use href="/ui.svg#moon"></use>
      </svg>
    </button>
  </div>
</div>

<style>
  #drawer.open {
    @apply h-full;
  }
</style>
